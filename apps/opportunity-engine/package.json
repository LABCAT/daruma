{
  "name": "opportunity-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply daruma-opportunity-engine --local",
    "dev:orchestrator": "wrangler dev --config workers/orchestrator/wrangler.toml",
    "dev:collect": "wrangler dev --config workers/collect/wrangler.toml",
    "dev:score": "wrangler dev --config workers/score/wrangler.toml",
    "dev:dashboard": "wrangler dev --config workers/dashboard/wrangler.toml"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2",
    "wrangler": "^3.101.0"
  }
}
